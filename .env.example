# Copy this file to .env and fill in all values before running docker compose.
# .env must never be committed to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=pls_user
DB_PASSWORD=                          # strong random password
DB_ROOT_PASSWORD=                     # strong random root password

# ── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=

# ── Admin bootstrap account ──────────────────────────────────────────────────
# The admin account is seeded on first startup. Password change is forced on first login.
# PLS_ADMIN_PASSWORD is required in production — startup will abort if unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                       # strong random password

# ── Test/presentation user (remove before production launch) ─────────────────
TEST_USER_USERNAME=user
TEST_USER_PASSWORD=                   # any password for testing

# ── MQTT broker ──────────────────────────────────────────────────────────────
# Must match the credentials in mosquitto/passwd.
# Generate passwd file: docker run --rm eclipse-mosquitto:2 mosquitto_passwd -c /tmp/p pls-backend
MQTT_USERNAME=pls-backend
MQTT_PASSWORD=                        # strong random password
# Set to true to omit name/longitude/latitude from MQTT payloads (privacy for external integrations).
# Core triage fields (triagefarbe, atmung, etc.) are always included.
MQTT_REDACT_PERSONAL_DATA=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to deny all cross-origin.
# Example: ALLOWED_ORIGINS=https://pls.example.com
ALLOWED_ORIGINS=
