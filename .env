# Database
DB_USER=pls_user
DB_PASSWORD=pls_password
DB_ROOT_PASSWORD=pls_root_password

# JWT — must be at least 32 characters, cryptographically random
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Admin bootstrap account — password is required in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Test/presentation user — remove before production launch
TEST_USER_USERNAME=user
TEST_USER_PASSWORD=password

# MQTT broker credentials — must match mosquitto/passwd
MQTT_USERNAME=pls-backend
MQTT_PASSWORD=pls-mqtt-password

# CORS — comma-separated list of allowed origins for production
# Leave empty to deny all cross-origin requests
ALLOWED_ORIGINS=
